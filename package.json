{
  "name": "@skaperiet/akse",
  "version": "0.1.0",
  "description": "Akse — 3D-modelleringsverktøy for barn og unge (akse3d.no)",
  "type": "module",
  "license": "UNLICENSED",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./akse-theme.css": "./dist/akse-theme.css"
  },
  "files": [
    "dist",
    "static"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync",
    "package": "svelte-kit sync && svelte-package && publint",
    "prepublishOnly": "npm run package",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "peerDependencies": {
    "svelte": "^5.0.0",
    "three": "^0.171.0",
    "three-bvh-csg": "^0.0.17"
  },
  "dependencies": {
    "file-saver": "^2.0.5",
    "opentype.js": "^1.3.4",
    "polygon-clipping": "^0.15.7"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^3.2.5",
    "@sveltejs/kit": "^2.6.0",
    "@sveltejs/package": "^2.3.7",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@types/file-saver": "^2.0.7",
    "@types/opentype.js": "^1.3.8",
    "@types/three": "^0.171.0",
    "publint": "^0.2.12",
    "svelte": "^5.0.0",
    "svelte-check": "^3.6.0",
    "three": "^0.171.0",
    "three-bvh-csg": "^0.0.17",
    "typescript": "^5.5.0",
    "vite": "^5.4.8"
  }
}
